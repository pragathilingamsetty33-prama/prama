# Root .gitignore for Prama Project

# IDEs and System files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*.log
hs_err_pid*
replay_pid*

# Node / React / React Native (FrontendWeb & FrontendMobile)
node_modules/
dist/
build/
.expo/
*.jks
*.p12
*.key
*.mobileprovision
web-build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Java / Spring Boot (Backend)
target/
!.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
bin/
out/
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# Specific Prama files to ignore
cors.json
